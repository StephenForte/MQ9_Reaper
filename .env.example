# Browser-restricted Maps JavaScript API key (referrer + Maps JS API only).
# Exposed to the client intentionally — restrict by HTTP referrer in Google Cloud Console.
# Create at: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# Server-only Geocoding API key (Geocoding API only).
# Never sent to the browser. Required for address input; map click / lat-long work without it.
#
# IMPORTANT: do NOT reuse your Maps JS key if it has HTTP referrer restrictions.
# Server geocoding calls have no browser referrer — Google returns REQUEST_DENIED.
#
# How to create a dedicated geocoding key:
# 1. Open https://console.cloud.google.com/google/maps-apis
# 2. Enable "Geocoding API" for your project
# 3. Credentials → Create credentials → API key (new key)
# 4. Application restrictions: None (local) or IP addresses (Render egress in prod)
#    — never "HTTP referrers" for this key
# 5. API restrictions → Geocoding API only
# 6. Paste below (or set on Render)
GEOCODING_API_KEY=

# Optional. Override the public Overpass API endpoint used by GET /api/overpass.
# Default: https://overpass-api.de/api/interpreter
# OVERPASS_API_URL=

# Optional. Defaults to 3000 locally; Render sets PORT automatically.
PORT=3000

# Optional. Override the config file path (absolute). On Render, Blueprint sets
# CONFIG_PATH=/var/data/app-config.md on the persistent disk. Locally, leave
# unset to use config/app-config.md in the repo.
# CONFIG_PATH=

# Optional. Directory for saved target JSON files. Defaults to
# dirname(CONFIG_PATH)/targets when CONFIG_PATH is persistent, else
# data/targets locally. On Render, Blueprint sets TARGETS_PATH=/var/data/targets.
# TARGETS_PATH=

# Remote MCP (optional). When set (16+ chars), enables Streamable HTTP MCP at /mcp.
# Cursor can use: Authorization: Bearer <MCP_API_KEY>
# Generate one with: node -e "console.log(require('crypto').randomUUID())"
# Leave empty to keep /mcp disabled (503).
MCP_API_KEY=

# Claude.ai / ChatGPT custom connector OAuth (optional; requires MCP_API_KEY).
# Paste Client ID + Secret into Claude or ChatGPT (Developer mode) connector settings.
# MCP_PUBLIC_URL must be the public https origin (no path), e.g. https://mq9-reaper.onrender.com
# On Render, RENDER_EXTERNAL_URL is used if MCP_PUBLIC_URL is unset.
# MCP_OAUTH_CLIENT_ID=
# MCP_OAUTH_CLIENT_SECRET=
# MCP_PUBLIC_URL=

# P6 Admin (optional). Leave empty to keep the Admin tab hidden.
# ADMIN_PASSWORD must be at least 12 characters or Admin stays disabled.
# ADMIN_SESSION_SECRET (16+) signs session cookies — recommended in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
