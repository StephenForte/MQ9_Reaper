{
  "name": "mq9-reaper",
  "version": "0.1.0",
  "description": "Map target selection app — pin, shortlist, annotate, and review geographic points",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/*.test.js test/*.test.mjs",
    "health": "node -e \"fetch('http://localhost:'+(process.env.PORT||3000)+'/api/health').then(r=>r.json()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "engines": {
    "node": ">=18"
  },
  "private": true,
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}
